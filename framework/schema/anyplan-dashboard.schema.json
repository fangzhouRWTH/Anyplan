{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anyplan.dev/schemas/anyplan-dashboard.schema.json",
  "title": "Anyplan Project Dashboard",
  "description": "Structured project overview, roadmap, and task progress for the visual engine. Pairs with a guidance instance at instances/<project-id>/guidance.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projectId", "overview", "roadmap", "completedTasks", "currentPhase"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^0\\.[0-9]+\\.[0-9]+$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "overview": {
      "$ref": "#/$defs/overview"
    },
    "roadmap": {
      "$ref": "#/$defs/roadmap"
    },
    "completedTasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/taskRecord"
      }
    },
    "currentPhase": {
      "$ref": "#/$defs/currentPhase"
    }
  },
  "$defs": {
    "overview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "highlights"],
      "properties": {
        "status": {
          "enum": ["bootstrap", "active", "maintenance", "paused"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "highlights": {
          "$ref": "#/$defs/stringList"
        },
        "owners": {
          "$ref": "#/$defs/stringList"
        },
        "documentPath": {
          "type": "string",
          "minLength": 1
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "roadmap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "phases"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "documentPath": {
          "type": "string",
          "minLength": 1
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/phase"
          }
        }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "summary"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["planned", "active", "completed"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "milestones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/milestone"
          }
        },
        "documentPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "summary"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["planned", "active", "completed"]
        }
      }
    },
    "currentPhase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseId", "title", "summary", "tasks"],
      "properties": {
        "phaseId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "progressPercent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "documentPath": {
          "type": "string",
          "minLength": 1
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phaseTask"
          }
        }
      }
    },
    "phaseTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "status", "summary"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": ["todo", "in-progress", "done", "blocked"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "string"
        },
        "blockers": {
          "$ref": "#/$defs/stringList"
        },
        "documentPath": {
          "type": "string",
          "minLength": 1
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "taskRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "completedAt", "summary"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "completedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "phaseId": {
          "$ref": "#/$defs/id"
        },
        "details": {
          "type": "string"
        },
        "documentPath": {
          "type": "string",
          "minLength": 1
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
