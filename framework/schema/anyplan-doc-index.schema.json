{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anyplan.dev/schemas/anyplan-doc-index.schema.json",
  "title": "Anyplan Document Index",
  "description": "Generated index of project Markdown files for the visual engine. Produced by scripts/build-doc-index.py.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projectId", "generatedAt", "entries"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^0\\.[0-9]+\\.[0-9]+$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "entryCount": {
      "type": "integer",
      "minimum": 0
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "title", "category", "contentType", "summary", "inclusionReason"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "enum": [
            "overview",
            "state",
            "roadmap",
            "decision",
            "evidence",
            "log",
            "methodology",
            "rule",
            "task-scope",
            "other"
          ]
        },
        "contentType": {
          "enum": ["markdown"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "inclusionReason": {
          "type": "string",
          "minLength": 1
        },
        "memoryType": {
          "type": "string",
          "minLength": 1
        },
        "documentId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        },
        "linkedFrom": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "title", "line"],
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
